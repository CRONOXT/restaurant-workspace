generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sucursal {
  id          String     @id @default(uuid())
  nombre      String
  direccion   String?
  numeroMesas Int        @default(0)
  mesas       Mesa[]
  menus       Menu[]
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  usuarios    Usuario[]
}

model Mesa {
  id          String     @id @default(uuid())
  numero      Int
  capacidad   Int        @default(2)
  sucursalId  String
  sucursal    Sucursal   @relation(fields: [sucursalId], references: [id])
  qrCode      String     @unique @default(uuid()) // Identifier for the QR URL
  isActive    Boolean    @default(true)
  isOccupied  Boolean    @default(false)
  pedidos     Pedido[]
  sesiones    Sesion[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Sesion {
  id          String      @id @default(uuid())
  mesaId      String
  mesa        Mesa        @relation(fields: [mesaId], references: [id])
  codigo      String      @unique  // Código de 6 dígitos para invitar
  isActive    Boolean     @default(true)
  comensales  Comensal[]
  pedidos     Pedido[]
  createdAt   DateTime    @default(now())
  closedAt    DateTime?
}

model Comensal {
  id          String    @id @default(uuid())
  sesionId    String
  sesion      Sesion    @relation(fields: [sesionId], references: [id])
  nombre      String
  token       String    @unique @default(uuid())
  esLider     Boolean   @default(false)
  pedidos     Pedido[]
  createdAt   DateTime  @default(now())
}

enum EstadoPedido {
  PENDIENTE
  ACEPTADO
  ENTREGADO
}

model Pedido {
  id            String        @id @default(uuid())
  mesaId        String
  mesa          Mesa          @relation(fields: [mesaId], references: [id])
  sesionId      String?
  sesion        Sesion?       @relation(fields: [sesionId], references: [id])
  comensalId    String?
  comensal      Comensal?     @relation(fields: [comensalId], references: [id])
  esCompartido  Boolean       @default(false)
  items         Json          // Array de { productoId, nombre, precio, cantidad }
  estado        EstadoPedido  @default(PENDIENTE)
  total         Float         @default(0)
  notas         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Menu {
  id          String      @id @default(uuid())
  nombre      String
  sucursalId  String
  sucursal    Sucursal    @relation(fields: [sucursalId], references: [id])
  categorias  Categoria[]
  moneda      String      @default("USD")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Categoria {
  id          String     @id @default(uuid())
  nombre      String
  menuId      String
  menu        Menu       @relation(fields: [menuId], references: [id])
  productos   Producto[]
  orden       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Producto {
  id          String     @id @default(uuid())
  nombre      String
  descripcion String?
  precio      Float
  imagen      String?
  disponible  Boolean    @default(true)
  categoriaId String
  categoria   Categoria  @relation(fields: [categoriaId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum Rol {
  ADMIN
  GERENTE
  CAMARERO
}

model Usuario {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  nombre      String
  rol         Rol       @default(CAMARERO)
  
  // Relaciones opcionales dependiendo del nivel de acceso
  sucursalId  String?
  sucursal    Sucursal? @relation(fields: [sucursalId], references: [id])
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
